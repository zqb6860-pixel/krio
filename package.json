{
  "name": "lightwords",
  "version": "1.0.0",
  "private": true,
  "description": "LightWords / 简词 - 英语学习App",
  "workspaces": [
    "shared",
    "app/lightwords-web"
  ],
  "scripts": {
    "web:dev": "npm run dev --workspace=app/lightwords-web",
    "web:build": "npm run build --workspace=app/lightwords-web",
    "app:start": "npm run start --workspace=app/lightwords-app",
    "shared:build": "npm run build --workspace=shared",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3"
  }
}
