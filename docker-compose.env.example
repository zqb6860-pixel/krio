# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-password-here
POSTGRES_DB=lightwords

# Server
JWT_SECRET=your-jwt-secret-at-least-32-chars
CORS_ORIGIN=http://localhost:3000

# Word Import (auto-import on container startup)
# "all" = import all word books
# Or comma-separated: "cet4,cet6,ielts,postgrad,middle,high,toefl,gre,tem4,tem8,daily,business"
# Leave empty or remove to skip import
IMPORT_BOOKS=all

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001/api
