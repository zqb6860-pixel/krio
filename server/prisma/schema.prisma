generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== 用户系统 ====================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  passwordHash  String
  avatar        String?
  level         Int      @default(1)
  experience    Int      @default(0)
  coins         Int      @default(100)
  hearts        Int      @default(5)
  streak        Int      @default(0)
  lastStudyDate String?  // YYYY-MM-DD
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  settings        UserSettings?
  learningRecords LearningRecord[]
  checkins        Checkin[]
  achievements    UserAchievement[]
  levelResults    LevelResult[]

  @@map("users")
}

model UserSettings {
  id             String  @id @default(cuid())
  userId         String  @unique
  dailyWordGoal  Int     @default(30)
  dailyTimeGoal  Int     @default(30)
  weeklyDaysGoal Int     @default(5)
  pronunciation  String  @default("us")
  theme          String  @default("light")
  fontSize       String  @default("medium")
  reminderTime   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ==================== 词库系统 ====================

model WordBook {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  wordCount   Int      @default(0)
  coverImage  String?
  difficulty  Int      @default(3)
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())

  words WordBookWord[]

  @@map("word_books")
}

model Word {
  id         String   @id @default(cuid())
  word       String   @unique
  phonetic   String?
  phoneticUs String?
  phoneticUk String?
  audioUs    String?
  audioUk    String?
  difficulty Int      @default(3)
  frequency  Int      @default(0)
  createdAt  DateTime @default(now())

  meanings     WordMeaning[]
  roots        WordRoot[]
  collocations WordCollocation[]
  examples     WordExample[]
  bookEntries  WordBookWord[]
  records      LearningRecord[]
  exercises    Exercise[]

  @@map("words")
}

model WordMeaning {
  id           String @id @default(cuid())
  wordId       String
  partOfSpeech String
  definition   String
  translation  String
  order        Int    @default(0)

  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@map("word_meanings")
}

model WordRoot {
  id           String @id @default(cuid())
  wordId       String
  root         String
  meaning      String
  origin       String
  type         String
  relatedWords String @default("[]") // JSON string for SQLite compatibility

  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@map("word_roots")
}

model WordCollocation {
  id          String  @id @default(cuid())
  wordId      String
  phrase      String
  translation String
  example     String?

  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@map("word_collocations")
}

model WordExample {
  id          String  @id @default(cuid())
  wordId      String
  sentence    String
  translation String
  source      String
  sourceYear  String?
  audioUrl    String?

  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@map("word_examples")
}

model WordBookWord {
  id         String @id @default(cuid())
  wordBookId String
  wordId     String
  order      Int    @default(0)

  wordBook WordBook @relation(fields: [wordBookId], references: [id], onDelete: Cascade)
  word     Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([wordBookId, wordId])
  @@map("word_book_words")
}

// ==================== 学习记录 ====================

model LearningRecord {
  id             String    @id @default(cuid())
  userId         String
  wordId         String
  status         String    @default("new")
  masteryLevel   Int       @default(0)
  easeFactor     Float     @default(2.5)
  interval       Int       @default(0)
  repetitions    Int       @default(0)
  reviewCount    Int       @default(0)
  correctCount   Int       @default(0)
  incorrectCount Int       @default(0)
  lastReviewAt   DateTime?
  nextReviewAt   DateTime?
  firstLearnedAt DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@map("learning_records")
}

// ==================== 打卡系统 ====================

model Checkin {
  id            String   @id @default(cuid())
  userId        String
  date          String
  wordsLearned  Int      @default(0)
  wordsReviewed Int      @default(0)
  timeSpent     Int      @default(0)
  correctRate   Float    @default(0)
  coinsEarned   Int      @default(0)
  expEarned     Int      @default(0)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("checkins")
}

// ==================== 成就系统 ====================

model Achievement {
  id          String @id @default(cuid())
  name        String
  description String
  icon        String
  category    String
  requirement Int
  rewardCoins Int    @default(0)
  rewardExp   Int    @default(0)

  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String    @id @default(cuid())
  userId        String
  achievementId String
  progress      Int       @default(0)
  isUnlocked    Boolean   @default(false)
  unlockedAt    DateTime?

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// ==================== 闯关系统 ====================

model LearningPath {
  id          String @id @default(cuid())
  name        String
  description String
  category    String
  order       Int    @default(0)
  icon        String @default("📚")

  units Unit[]

  @@map("learning_paths")
}

model Unit {
  id          String @id @default(cuid())
  pathId      String
  title       String
  description String
  order       Int    @default(0)
  icon        String @default("📖")

  path   LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  levels Level[]

  @@map("units")
}

model Level {
  id          String  @id @default(cuid())
  unitId      String
  title       String
  description String?
  order       Int     @default(0)
  unlockAfter String?

  unit      Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  exercises Exercise[]
  results   LevelResult[]

  @@map("levels")
}

model Exercise {
  id            String  @id @default(cuid())
  levelId       String
  wordId        String?
  type          String
  question      String
  options       String  @default("[]") // JSON string for SQLite
  correctAnswer String
  explanation   String?
  audioUrl      String?
  imageUrl      String?
  order         Int     @default(0)

  level Level @relation(fields: [levelId], references: [id], onDelete: Cascade)
  word  Word? @relation(fields: [wordId], references: [id])

  @@map("exercises")
}

model LevelResult {
  id          String   @id @default(cuid())
  userId      String
  levelId     String
  stars       Int      @default(0)
  score       Int      @default(0)
  maxCombo    Int      @default(0)
  completedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  level Level @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@map("level_results")
}
